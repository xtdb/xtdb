-- db.allium
--
-- The processing model of a single database within an XTDB node:
-- transaction submission → log processing → block flushing → query.
-- Compaction job selection and algorithm are specified in compaction.allium;
-- the compaction message flow is here.
--
-- Scope: one database (e.g. "xtdb" or a secondary).
-- External: the multi-database orchestration layer (attach/detach).
--
-- Source and replica are always separate logs (invariant, not just convention).
-- A LogProcessor owns the indexing pipeline lifecycle per database.
-- Compactor is a peer at db-system level, not a child of the processor.
-- Leader/follower transitions driven by Kafka consumer group rebalancing (or local log startup).
-- A single LiveIndex sits outside the processor as shared state.
-- Leader mode feeds it from source processing; follower mode feeds it from replica processing.
-- A single Watchers instance tracks both txId and sourceMsgId for client correlation.
-- Follower→leader transition sync uses a separate MutableStateFlow on the FollowerProcessor,
-- not Watchers (see FollowerProcessor.awaitReplicaMsgId).
-- The compactor writes L1+ to the source log; the leader forwards to replica.

use "./trie-cat.allium" as trie_cat
use "./compaction.allium" as compaction

---- Context

context {
    database: Database
    log_processor: LogProcessor
    live_index: LiveIndex              -- shared across leader/follower modes
    watchers: Watchers                 -- single instance: correlates source msg_ids and tx_ids with client futures
    block_catalog: BlockCatalog
    table_catalog: TableCatalog
    block_uploader: BlockUploader      -- shared by leader, transition processor
    compactor: Compactor.ForDatabase   -- peer of log_processor at db-system level
}

---- External Entities

external entity Client {
    -- The party submitting transactions.
}

external entity Log {
    -- An ordered, append-only message stream.
    -- Two separate instances per database: source_log and replica_log.
    -- They MUST be distinct logs (not aliases for the same underlying log).
    -- See: api/log/Log.kt
}

external entity ObjectStore {
    -- Durable key-value storage for blocks, tries, table-blocks.
}

---- Entities

entity LiveIndex {
    -- See: indexer/LiveIndex.kt
    -- Single instance shared across leader and follower modes.
    latest_completed_tx: TransactionKey?
    is_full: Boolean

    -- Derived
    has_data: latest_completed_tx != null
}

entity Database {
    -- See: indexer/Indexer.kt
    source_log: Log
    replica_log: Log

    invariant: source_log != replica_log
        -- Source and replica are always distinct logs.
}

entity LogProcessor {
    -- See: indexer/LogProcessor.kt
    -- Owns the indexing pipeline lifecycle for a database.
    -- Implements Log.SubscriptionListener (onPartitionsAssigned/Revoked drive transitions).
    -- Starts in follower mode. Always in exactly one mode.
    --
    -- Every processor tracks BOTH positions:
    --   latest_source_msg_id: highest source-log message id that has been processed.
    --   latest_replica_msg_id: highest replica-log message id that has been processed.
    -- Both positions are needed during transitions so the new processor starts from
    -- the right place.
    --
    -- Transitions are driven by Kafka consumer group rebalancing:
    --   onPartitionsAssigned → TransitionToLeader
    --   onPartitionsRevoked  → TransitionToFollower
    -- For local log, the single node is always immediately assigned.
    mode: Leader | Follower | Transition
    latest_source_msg_id: MessageId
    latest_replica_msg_id: MessageId
}

variant Leader : LogProcessor {
    -- Subscribes to the source log, resolves messages,
    -- writes resolved output to the replica log.
    -- Also owns block finishing via BlockUploader.
    -- See: indexer/LeaderLogProcessor.kt
    pending_block: PendingBlock?  -- set between BlockBoundary and BlockUploaded during finishBlock
}

variant Follower : LogProcessor {
    -- Subscribes to the replica log.
    -- Feeds the shared live_index from replica messages.
    -- Exposes pending_block state for handoff during leader transition.
    -- awaitReplicaMsgId uses a MutableStateFlow updated in the finally block
    -- of processRecords — after every record, including errors.
    -- See: indexer/FollowerLogProcessor.kt
    pending_block: PendingBlock?
}

variant Transition : LogProcessor {
    -- Processes replica messages during leader startup.
    -- Used to replay buffered records from a pending block and any
    -- BlockBoundary messages encountered during the replay.
    -- On BlockBoundary: directly calls blockUploader.uploadBlock() (unlike the
    -- follower, which enters pending mode and waits for BlockUploaded).
    -- See: indexer/TransitionLogProcessor.kt
}

entity BlockCatalog {
    -- See: catalog/BlockCatalog.kt
    latest_block: Block?

    -- Derived
    current_block_index: latest_block?.block_index
}

entity TableCatalog {
    -- See: catalog/TableCatalog.kt, table_catalog.clj
    table_metadata: Map<trie_cat/TableRef, TableMetadata>
}

entity Watchers {
    -- Single instance per database.
    -- Tracks both txId and sourceMsgId progression.
    -- Clients call awaitTx(txId) to wait for a transaction result.
    -- Transition code calls awaitSource(srcMsgId) to wait for source processing.
    --
    -- notifyTx(result, srcMsgId): advances both txId and sourceMsgId.
    -- notifyMsg(srcMsgId): advances only sourceMsgId (for non-tx messages like
    --   TriesAdded, FlushBlock, BlockBoundary, BlockUploaded).
    -- notifyError(exception): transitions to Failed state; all subsequent awaits throw.
    --
    -- See: api/log/Watchers.kt
    latest_tx_id: MessageId
    latest_source_msg_id: MessageId
    latest_tx_result: TransactionResult?

    -- Monotonicity invariants enforced at runtime:
    invariant: notifyTx must supply txId > latest_tx_id (strictly increasing)
    invariant: notifyTx and notifyMsg must supply srcMsgId >= latest_source_msg_id (non-decreasing)
        -- >= not >: BlockBoundary can carry the same source msgId as the preceding
        -- ResolvedTx when the block was triggered by isFull() (no FlushBlock in between).
}

entity BlockUploader {
    -- Shared class used by both LeaderLogProcessor (for normal block finishing)
    -- and TransitionLogProcessor (for completing interrupted blocks during transition).
    --
    -- uploadBlock(replicaProducer, boundaryMsgId, boundaryMessage):
    --   1. Finishes live index block (liveIndex.finishBlock)
    --   2. Registers L0 tries in trie catalog
    --   3. Finishes table catalog, writes table blocks
    --   4. Builds and persists block file to object store
    --   5. Writes BlockUploaded to replica log (via atomic producer)
    --   6. Calls liveIndex.nextBlock() and compactor.signalBlock()
    --   Returns the replica msg_id of the BlockUploaded message.
    --
    -- See: indexer/BlockUploader.kt
}

entity BlockFlusher {
    -- Extracted class that checks whether a block flush timeout has elapsed.
    -- Used by the leader at the start of each processRecords batch.
    -- See: indexer/BlockFlusher.kt
    flush_timeout: Duration
    last_flush_check: Instant
    previous_block_tx_id: MessageId
    flushed_tx_id: MessageId
}

external value current_storage_version: Int   -- See: storage/Storage.kt (VERSION)
external value current_storage_epoch: Int     -- See: buffer_pool/BufferPool.kt (epoch)

---- Values

value MessageId {
    -- Epoch + offset packed into a long.
    -- See: util/MsgIdUtil.kt
    epoch: Int
    offset: Int
}

value TransactionKey {
    -- See: block/proto/block.proto (TxKey)
    -- tx_id is monotonically increasing (assigned by the source log).
    -- system_time is NOT monotonic (clients can set arbitrary system times).
    -- Ordering comparisons MUST use tx_id, not system_time.
    tx_id: Long
    system_time: Instant
}

value Block {
    -- A persisted block in the object store.
    block_index: Long
    latest_completed_tx: TransactionKey
    latest_processed_msg_id: MessageId       -- source log
    latest_replica_msg_id: MessageId         -- replica log; msg id of the BlockBoundary message
}

value PendingBlock {
    -- Captures the state between BlockBoundary and BlockUploaded.
    -- In the follower: also buffers subsequent replica messages.
    -- In the leader: set during finishBlock, cleared after uploadBlock completes.
    -- Passed from leader to follower on revocation, and from follower to
    -- transition processor on assignment.
    -- See: indexer/PendingBlock.kt
    boundary_msg_id: MessageId
    boundary_message: BlockBoundaryMessage
    buffered_records: List<ReplicaMessage>   -- follower only; leader creates with no buffer
}

value Snapshot {
    as_of: TransactionKey
}

value TableMetadata {
    row_count: Long?
}

value DbOp {
    -- A database-level side-effect carried within a ResolvedTx.
    -- See: api/log/DbOp.kt
    kind: Attach | Detach
}

variant Attach : DbOp {
    db_name: String
    config: DatabaseConfig
}

variant Detach : DbOp {
    db_name: String
}

---- Source Log Messages

-- Messages on the source log. Written by clients, the leader (FlushBlock),
-- and the compactor (TriesAdded L1+).
-- See: log/proto/log.proto (LogMessage oneof)

entity SourceMessage {
    msg_id: MessageId
    log_timestamp: Instant
    kind: TxMessage | FlushBlockMessage | TriesAddedMessage
         | BlockUploadedMessage | AttachDbMessage | DetachDbMessage
}

variant TxMessage : SourceMessage {
    -- Client-submitted transaction operations.
    -- See: tx/TxWriter.kt, api/log/Log.kt, api/log/SourceMessage.kt (SourceMessage$Tx) — serialised via TxWriter, not proto.
    system_time: Instant?
    default_tz: ZoneId               -- always present (non-nullable)
    user: String?
    user_metadata: Bytes?            -- optional serialized user metadata
}

variant FlushBlockMessage : SourceMessage {
    -- Leader self-sends to trigger block flush on timeout.
    -- See: log/proto/log.proto (FlushBlock)
    expected_block_idx: Long?
}

variant TriesAddedMessage : SourceMessage {
    -- L1+ compaction results written by the compactor.
    -- The leader forwards these to the replica log.
    -- See: log/proto/log.proto (TriesAdded)
    storage_version: Int
    storage_epoch: Int
    tries: List<trie_cat/TrieDetails>
}

variant BlockUploadedMessage : SourceMessage {
    -- Written by the multi-writer path (SourceLogProcessor).
    -- The leader ignores this (notifies watchers only).
    -- See: log/proto/log.proto (BlockUploaded)
    storage_version: Int
    storage_epoch: Int
    block_index: Long
    latest_processed_msg_id: MessageId
    tries: List<trie_cat/TrieDetails>
}

variant AttachDbMessage : SourceMessage {
    -- See: log/proto/log.proto (AttachDatabase)
    db_name: String
    config: DatabaseConfig
}

variant DetachDbMessage : SourceMessage {
    -- See: log/proto/log.proto (DetachDatabase)
    db_name: String
}

---- Replica Log Messages

-- Messages on the replica log. Written exclusively by the leader.
-- Consumed by all nodes (including the leader's own follower, after transition).

entity ReplicaMessage {
    msg_id: MessageId
    log_timestamp: Instant
    kind: ResolvedTxMessage | BlockBoundaryMessage | BlockUploadedMessage
         | TriesAddedMessage | NoOpMessage
}

variant ResolvedTxMessage : ReplicaMessage {
    -- A resolved transaction: put/delete/erase events that require no database reads.
    -- Carries the source tx_id so watchers can correlate with submit-tx responses.
    -- Attach/detach results are encoded as a dbOp field within the resolved tx.
    -- See: api/log/Log.kt (Message.ResolvedTx), api/log/ReplicaMessage.kt (ResolvedTx)
    tx_id: MessageId            -- source-log msg id of the original Tx/Attach/Detach
    system_time: Instant        -- resolved system time for the transaction
    committed: Boolean
    error: Throwable?           -- abort reason (null if committed)
    db_op: DbOp?               -- Attach or Detach side-effect, if any
    table_data: Map<String, Bytes>  -- resolved row data per table, serialized; imported by replica processor
}

variant BlockBoundaryMessage : ReplicaMessage {
    -- Leader signals that a block boundary has been reached.
    -- Followers enter pending mode and buffer subsequent messages until BlockUploaded.
    -- L0 tries are delivered in the subsequent BlockUploaded message (not separately).
    -- See: log/proto/replica-log.proto (BlockBoundary)
    block_index: Long
    latest_processed_msg_id: MessageId   -- source log high-water at block time
}

variant BlockUploadedMessage : ReplicaMessage {
    -- Block has been written to the object store.
    -- Carries L0 tries so followers can update their trie catalogs.
    -- Followers refresh catalogs and transition out of pending mode.
    -- See: log/proto/log.proto (BlockUploaded)
    block_index: Long
    latest_processed_msg_id: MessageId
    storage_version: Int
    storage_epoch: Int
    tries: List<trie_cat/TrieDetails>
}

variant TriesAddedMessage : ReplicaMessage {
    -- New tries available.
    -- L1+ tries: forwarded by the leader from the source log (compactor writes).
    -- source_msg_id carries the original source-log position so that staleness
    -- checking and watchers can advance their watermarks correctly.
    -- See: log/proto/log.proto (TriesAdded), api/log/ReplicaMessage.kt (TriesAdded)
    storage_version: Int
    storage_epoch: Int
    tries: List<trie_cat/TrieDetails>
    source_msg_id: MessageId   -- source-log msg_id of the original TriesAdded
}

variant NoOpMessage : ReplicaMessage {
    -- No-operation message used for fencing during leader transition.
    -- The new leader sends a NoOp after opening the transactional producer,
    -- then the follower's awaitReplicaMsgId waits for it to ensure the follower
    -- has fully processed all prior messages before handoff.
    -- See: api/log/ReplicaMessage.kt (NoOp)
}

---- Config

config {
    flush_timeout: Duration = 5.minutes
    max_block_rows: Integer = 102400
}

---- Rules: Coordinator Transitions

-- Kafka consumer group rebalancing (or local log startup) drives transitions.
-- The LogProcessor serializes transitions: close old system, start new one.

-- == Fencing ==
--
-- The leader holds a transactional producer on the replica log.
-- Opening a new transactional producer fences the old one — no further
-- messages can be committed by the previous leader.
-- This guarantees at most one writer to the replica log at any time.
--
-- The source log is NOT fenced. Stale messages from a previous leader
-- (FlushBlock) or compactor (TriesAdded) may appear on the source log
-- after a transition. This is safe because:
--   - FlushBlock is a CAS on expected_block_idx; stale flushes fail the check.
--   - TriesAdded is idempotent; addTries tolerates duplicates.

-- == Transition Safety ==
--
-- close() on the active system MUST NOT interrupt an in-flight transaction
-- commit or import. Applying (resolving) a transaction is safe to interrupt
-- because it does not mutate the live index — only the commit/import step
-- writes to the live index. close() waits for any in-progress commit/import
-- to complete, then stops the subscription. This ensures the live index
-- always reflects a complete prefix of the replica log (for followers)
-- or source log (for the leader), never a partial transaction.

-- == Leader Startup ==
--
-- A new leader can always reconstruct correct state from:
--   1. The last persisted block (from block catalog)
--   2. The follower's in-memory state (which has been processing replica messages)
--
-- The fencing + NoOp + awaitReplicaMsgId sequence ensures the follower has
-- fully caught up before its state is captured and it is shut down.
-- If the follower had a pending block (saw BlockBoundary but not BlockUploaded),
-- the new leader finishes the block via BlockUploader before starting source
-- log consumption.

-- == Staleness ==
--
-- Both FollowerLogProcessor and TransitionLogProcessor use a staleness check
-- based on latest_source_msg_id as a watermark. A replica message is stale
-- if its source position is at or behind the watermark:
--   ResolvedTx: stale if txId <= latest_source_msg_id
--   TriesAdded: stale if source_msg_id <= latest_source_msg_id
--   BlockBoundary: stale if latest_processed_msg_id <= latest_source_msg_id
--   BlockUploaded: stale if latest_processed_msg_id <= latest_source_msg_id
--   NoOp: never stale
-- Stale messages are skipped entirely before dispatch. This replaces per-type
-- idempotency checks within the handler.

rule TransitionToLeader {
    when: PartitionsAssigned(database)
    requires: log_processor.mode is Follower

    ensures:
        -- Fence: open transactional producer on replica log.
        -- After this, the previous leader cannot commit further messages.
        let producer = database.replica_log.openTransactionalProducer()

        -- Send a NoOp to get a known msg_id (replay_target).
        -- We cannot use latestSubmittedMsgId because Kafka's endOffsets
        -- includes transaction marker offsets that consumers never deliver.
        let replay_target = NoOpMessage.created() appended to database.replica_log

        -- Wait for the follower to process all replica messages up to the NoOp.
        -- This uses FollowerProcessor.awaitReplicaMsgId (a MutableStateFlow),
        -- NOT Watchers. The flow is updated in the finally block of processRecords
        -- so it advances even on error.
        follower.awaitReplicaMsgId(replay_target)

        -- Close the follower system. No further processing after this point.
        follower.close()

        -- Capture the follower's pending block state (if it saw BlockBoundary
        -- but not BlockUploaded before the fence point).
        let pending_block = follower.pending_block

        -- Open a TransitionProcessor to replay any buffered records.
        -- It receives the follower's latest_source_msg_id and latest_replica_msg_id
        -- so it knows where the follower left off.
        let transition = Transition.created(
            after_source_msg_id: follower.latest_source_msg_id,
            after_replica_msg_id: follower.latest_replica_msg_id
        )

        -- If the follower had a pending block, the new leader must finish it.
        -- The pending block's data is already in the live index (written before
        -- BlockBoundary), but the block file was never persisted.
        if pending_block is set:
            -- Use BlockUploader to persist the block and write BlockUploaded.
            block_uploader.uploadBlock(
                producer,
                pending_block.boundary_msg_id,
                pending_block.boundary_message
            )
            -- Replay buffered records through the transition processor.
            -- The transition processor handles BlockBoundary by immediately
            -- calling blockUploader.uploadBlock (unlike the follower which
            -- enters pending mode).
            transition.processRecords(pending_block.buffered_records)

        -- Determine source log resume point from the transition processor.
        -- This accounts for all work done: follower processing + any replayed records.
        let source_resume = transition.latest_source_msg_id

        -- Switch to leader mode: subscribe to source log.
        -- The leader receives replay_target as its after_replica_msg_id so it
        -- knows where the replica log left off.
        log_processor.mode = Leader
        log_processor.start(source_resume, after_replica_msg_id: replay_target)

    invariant: ReplayEquivalence
        -- The live index state after transition is identical regardless of
        -- how much work the follower had already done.
}

rule TransitionToFollower {
    when: PartitionsRevoked(database)
    requires: log_processor.mode is Leader

    ensures:
        -- close() completes any in-flight commit, then stops.
        -- Capture the leader's positions and pending block before switching.
        let leader = log_processor as Leader
        leader.close()

        -- The leader's pending_block is passed to the new follower.
        -- If the leader was mid-block-flush when revoked (between BlockBoundary
        -- and BlockUploaded), the follower picks up the pending state.
        log_processor.mode = Follower
        log_processor.start(
            from_source: leader.latest_source_msg_id,
            from_replica: leader.latest_replica_msg_id,
            pending_block: leader.pending_block
        )
}

---- Rules: Transaction Submission

rule ClientSubmitsTransaction {
    when: ClientSubmitsTx(client, database, tx_ops, opts)

    requires: log_processor.mode is Leader

    ensures:
        let msg = TxMessage.created(
            system_time: opts.system_time,
            default_tz: opts.default_tz,
            user: opts.user
        )
        msg appended to database.source_log
}

---- Rules: Leader Mode (source processing)

-- The leader subscribes to the source log.
-- It resolves each message and writes the result to the replica log.
-- Feeds the shared live_index directly.
-- At the start of each processRecords batch, the leader checks the block
-- flush timeout via BlockFlusher.

rule LeaderProcessesTx {
    when: msg: TxMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id

    ensures:
        let resolved = IndexTransaction(msg)
        ResolvedTxMessage.created(
            tx_id: msg.msg_id,
            committed: resolved.committed,
            db_op: resolved.db_op
        ) appended to database.replica_log

        watchers.notifyTx(resolved.result, msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id

        if live_index.is_full:
            LeaderFinishesBlock(msg.msg_id)
}

rule LeaderProcessesAttachDb {
    when: msg: AttachDbMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id

    ensures:
        let resolved = ResolveAttach(msg)
        ResolvedTxMessage.created(
            tx_id: msg.msg_id,
            committed: resolved.committed,
            db_op: resolved.db_op
        ) appended to database.replica_log

        watchers.notifyTx(resolved.result, msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id
}

rule LeaderProcessesDetachDb {
    when: msg: DetachDbMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id

    ensures:
        let resolved = ResolveDetach(msg)
        ResolvedTxMessage.created(
            tx_id: msg.msg_id,
            committed: resolved.committed,
            db_op: resolved.db_op
        ) appended to database.replica_log

        watchers.notifyTx(resolved.result, msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id
}

rule LeaderProcessesFlushBlock {
    when: msg: FlushBlockMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id

    ensures:
        -- CAS check: only finish the block if the expected index matches.
        -- When the CAS fails (stale FlushBlock, or null expected_block_idx),
        -- we still advance watchers and latest_source_msg_id.
        if msg.expected_block_idx != null
           and msg.expected_block_idx == (block_catalog.current_block_index ?? -1):
            LeaderFinishesBlock(msg.msg_id)

        watchers.notifyMsg(msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id
}

rule LeaderProcessesTriesAdded {
    -- L1+ from compactor. The leader needs these in its trie catalog
    -- for correct partition info at block time, and forwards them to the replica log.
    when: msg: TriesAddedMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id
    requires: msg.storage_version == current_storage_version
    requires: msg.storage_epoch == current_storage_epoch

    ensures:
        -- Update the trie catalog (needed for finishBlock partition info).
        trie_cat/trie_catalog.addTries(msg.tries, msg.log_timestamp)

        -- Forward to replica log so followers see L1+ tries.
        -- Include source_msg_id so followers can advance their watermarks.
        TriesAddedMessage.created(
            storage_version: msg.storage_version,
            storage_epoch: msg.storage_epoch,
            tries: msg.tries,
            source_msg_id: msg.msg_id
        ) appended to database.replica_log

        watchers.notifyMsg(msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id
}

rule LeaderProcessesBlockUploaded {
    -- BlockUploaded on the source log is from the single-writer path.
    -- The leader ignores it (notifies watchers only).
    when: msg: BlockUploadedMessage consumed from database.source_log
    mode: log_processor.mode is Leader

    requires: msg.msg_id > log_processor.latest_source_msg_id

    ensures:
        watchers.notifyMsg(msg.msg_id)
        log_processor.latest_source_msg_id = msg.msg_id
}

---- Rules: Leader Block Finishing

-- The leader finishes blocks via BlockUploader.
-- The leader sets pending_block between writing BlockBoundary and BlockUploaded.
-- If the leader is revoked during this window, the pending block gets passed
-- to the follower (see TransitionToFollower).
--
-- Double-finish is not possible: LeaderFinishesBlock is fired by either
-- LeaderProcessesTx (when live_index.is_full) or LeaderProcessesFlushBlock.
-- These are processed sequentially on the source log subscription thread.
-- If LeaderProcessesTx triggers a flush, it finishes the block and calls
-- nextBlock() — the live index is no longer full. If a FlushBlock message
-- arrives later for the same block_index, its CAS (expected_block_idx ==
-- block_catalog.current_block_index) fails because the block catalog has
-- already advanced.

rule LeaderFinishesBlock {
    when: LeaderFinishesBlock(latest_processed_msg_id)

    let block_index = (block_catalog.current_block_index ?? -1) + 1

    ensures:
        -- Signal replica: block boundary first.
        -- The BlockBoundary message's msg_id becomes the block's
        -- latest_replica_msg_id — the resume point for replica log subscriptions.
        let block_boundary = BlockBoundaryMessage.created(
            block_index: block_index,
            latest_processed_msg_id: latest_processed_msg_id
        )
        block_boundary appended to database.replica_log

        -- Set pending_block between boundary and upload.
        -- If revoked during this window, the pending block is handed to the follower.
        log_processor.pending_block = PendingBlock(
            boundary_msg_id: block_boundary.msg_id,
            boundary_message: block_boundary
        )

        -- Use BlockUploader to finish the block.
        -- This persists tries, table blocks, block file, writes BlockUploaded,
        -- calls nextBlock() and signals the compactor.
        block_uploader.uploadBlock(
            producer,
            block_boundary.msg_id,
            block_boundary
        )

        log_processor.pending_block = null
}

---- Rules: Leader Flush Timeout

rule LeaderFlushTimeout {
    -- BlockFlusher checks at the start of each processRecords batch.
    -- It compares the current block's latest tx_id against the previous check.
    -- If the block hasn't advanced after flush_timeout, and we haven't already
    -- flushed this tx, it returns true and the leader writes FlushBlock to source.
    -- See: indexer/BlockFlusher.kt
    when: block_flusher.checkBlockTimeout() == true
    mode: log_processor.mode is Leader

    requires: live_index.has_data

    ensures:
        FlushBlockMessage.created(
            expected_block_idx: block_catalog.current_block_index
        ) appended to database.source_log
}

---- Rules: Replica Message Handling

-- Staleness-based skip: before dispatching any replica message,
-- the processor checks if the message is stale (source position at or behind
-- the latest_source_msg_id watermark). Stale messages are skipped entirely.
-- This replaces per-type idempotency checks.
--
-- In the follower, staleness is checked OUTSIDE the pending block guard:
-- if in pending mode, the pending block handler runs first (buffers or matches
-- BlockUploaded). Only non-pending, non-stale messages reach processRecord.
--
-- In the transition processor, all messages go through the stale check first.

-- == Follower HandleRecord dispatch ==
--
-- The follower's handleRecord has two phases:
-- 1. Pending block guard: if pending_block is set, check if the message is
--    a matching BlockUploaded. If so, finish the block. Otherwise buffer.
--    Return in either case.
-- 2. Staleness check: if the message is stale, skip. Otherwise processRecord.

rule HandleReplicaMessage {
    -- Dispatches a single replica message after staleness check passes.
    -- Used by the follower processor. The transition processor overrides
    -- specific message types (see Transition rules below).
    when: msg: ReplicaMessage

    ensures:
        if msg is ResolvedTxMessage:
            live_index.importTx(msg)
            if msg.committed:
                if msg.db_op is Attach:
                    database.catalog.attach(msg.db_op.db_name, msg.db_op.config)
                if msg.db_op is Detach:
                    database.catalog.detach(msg.db_op.db_name)
            log_processor.latest_source_msg_id = msg.tx_id
            watchers.notifyTx(result, msg.tx_id)

        if msg is TriesAddedMessage:
            requires: msg.storage_version == current_storage_version
            requires: msg.storage_epoch == current_storage_epoch
            trie_cat/trie_catalog.addTries(msg.tries, msg.log_timestamp)
            log_processor.latest_source_msg_id = msg.source_msg_id
            watchers.notifyMsg(msg.source_msg_id)

        if msg is BlockBoundaryMessage:
            -- Follower: enters pending mode. Subsequent messages (except a matching
            -- BlockUploaded) will be buffered by the pending block guard above.
            -- Also advances latest_source_msg_id and notifies watchers.
            pending_block = PendingBlock(msg.record_msg_id, msg)
            log_processor.latest_source_msg_id = msg.latest_processed_msg_id
            watchers.notifyMsg(msg.latest_processed_msg_id)

        if msg is BlockUploadedMessage:
            -- In the follower's normal (non-pending) path, this handles
            -- BlockUploaded messages that aren't matched to a pending block
            -- (e.g. stale ones that passed the stale check).
            -- Adds L0 tries and notifies watchers.
            requires: msg.storage_version == current_storage_version
            requires: msg.storage_epoch == current_storage_epoch
            trie_cat/trie_catalog.addTries(msg.tries, msg.log_timestamp)
            watchers.notifyMsg(msg.latest_processed_msg_id)

        if msg is NoOpMessage:
            -- No-op; used for fencing synchronization only.
            pass
}

rule FollowerHandlesBlockUploaded {
    -- When the follower is in pending mode and receives the matching
    -- BlockUploaded message, it finishes the block by reading the block
    -- file from the object store (via buffer pool), not from the message.
    -- The BlockUploaded message is just a signal.
    when: msg: BlockUploadedMessage
    requires: pending_block is set
    requires: msg.block_index == pending_block.block_index
    requires: msg.storage_epoch == current_storage_epoch

    ensures:
        -- Read the block file from the object store.
        let block = Block.parseFrom(buffer_pool.getByteArray(blockFilePath(pending_block.block_index)))
        block_catalog.refresh(block)
        live_index.nextBlock()
        CompactorSignalled()

        -- Clear pending mode and replay buffered records.
        let buffered = pending_block.buffered_records
        pending_block = null
        ReplayBuffered(buffered)
}

---- Rules: Transition Processor Message Handling

-- The transition processor handles replica messages differently from the follower:
--
-- 1. BlockBoundary: instead of entering pending mode, it immediately calls
--    blockUploader.uploadBlock to persist the block.
--
-- 2. ResolvedTx: has an extra txId guard on importTx. During transition,
--    the live index may already contain transactions from follower processing.
--    The follower relies on the staleness check (which skips the entire message
--    including importTx), but the transition processor additionally guards
--    importTx itself: only calls it if txId > live_index.latest_completed_tx.tx_id.
--    This is because the transition processor's staleness watermark may not
--    perfectly align with what the live index has already imported.

rule TransitionHandlesResolvedTx {
    -- Extra guard: only importTx if the tx hasn't already been applied.
    when: msg: ResolvedTxMessage
    mode: log_processor.mode is Transition

    ensures:
        if live_index.latest_completed_tx == null
           or msg.tx_id > live_index.latest_completed_tx.tx_id:
            live_index.importTx(msg)
        if msg.committed:
            if msg.db_op is Attach:
                database.catalog.attach(msg.db_op.db_name, msg.db_op.config)
            if msg.db_op is Detach:
                database.catalog.detach(msg.db_op.db_name)
        log_processor.latest_source_msg_id = msg.tx_id
        watchers.notifyTx(result, msg.tx_id)
}

rule TransitionHandlesBlockBoundary {
    -- On BlockBoundary: directly finish the block via BlockUploader.
    -- This is different from the follower, which enters pending mode.
    when: msg: BlockBoundaryMessage
    mode: log_processor.mode is Transition

    ensures:
        block_uploader.uploadBlock(
            producer,
            msg.record_msg_id,
            msg
        )
        log_processor.latest_source_msg_id = msg.latest_processed_msg_id
        watchers.notifyMsg(msg.latest_processed_msg_id)
}

rule TransitionHandlesBlockUploaded {
    -- BlockUploaded messages are ignored by the transition processor
    -- (the block was already uploaded by the BlockBoundary handler above).
    -- But it still advances the watermarks.
    when: msg: BlockUploadedMessage
    mode: log_processor.mode is Transition

    ensures:
        log_processor.latest_source_msg_id = msg.latest_processed_msg_id
        watchers.notifyMsg(msg.latest_processed_msg_id)
}

---- Rules: Follower Mode

-- The follower subscribes to the replica log and dispatches each
-- message through handleRecord (pending block guard → staleness → processRecord).
-- latest_replica_msg_id is updated in the finally block of processRecords,
-- after every record including errors. This is what awaitReplicaMsgId waits on.

rule FollowerProcessesMessage {
    when: msg: ReplicaMessage consumed from database.replica_log
    mode: log_processor.mode is Follower

    ensures:
        HandleRecord(msg)
        -- Updated in finally block, not conditionally:
        log_processor.latest_replica_msg_id = msg.record_msg_id
}

---- Rules: Compaction Orchestration

-- The compactor runs asynchronously, triggered after block flushes.
-- Job selection and the merge algorithm are specified in compaction.allium.
-- The compactor writes L1+ TriesAdded to the source log (not the replica log).
-- The leader forwards these to the replica log.

rule CompactorWakesUp {
    when: CompactorSignalled()

    let jobs = compaction/available_jobs(trie_cat/trie_catalog)

    ensures:
        for each job in jobs:
            StartCompactionJob(job)
}

rule CompactionJobWritesOutput {
    when: StartCompactionJob(job)

    ensures:
        -- Data file uploaded first; meta file presence is the completion marker.

        -- Write TriesAdded to the source log.
        -- The leader will forward to the replica log.
        TriesAddedMessage.created(tries: job.output_tries) appended to database.source_log
}

rule CompactionJobConfirmed {
    -- The TriesAdded has round-tripped through the log and is now in the trie catalog.
    -- Job selection naturally sees the updated catalog for the next cycle.
    when: job.output_tries visible in trie_cat/trie_catalog
}

---- Rules: Query Serving

rule ClientOpensSnapshot {
    when: ClientOpensSnapshot(client, database)

    ensures:
        Snapshot.created(
            as_of: live_index.latest_completed_tx
        )
}

---- Rules: Error Handling

rule ProcessingErrorHaltsNode {
    -- On processing error, watchers.notifyError transitions Watchers to Failed state.
    -- All subsequent awaitTx/awaitSource calls throw the exception.
    when: ProcessingError(msg_id, error)

    ensures:
        watchers.notifyError(error)
        NodeMarkedUnhealthy()
}

---- Surfaces

actor Client {
    identified_by: external session
}

surface TransactionSubmission {
    for caller: Client

    context db: Database

    provides:
        ClientSubmitsTx(caller, db, tx_ops, opts)
            when log_processor.mode is Leader

    invariant: OrderedProcessing
        -- Transactions are processed in the order they appear in the source log.
}

surface QueryAccess {
    for caller: Client

    context db: Database

    provides:
        ClientOpensSnapshot(caller, db)

    invariant: SnapshotIsolation
        -- A snapshot sees a consistent point-in-time view.
        -- It includes all transactions up to latest_completed_tx.
}

---- Deferred Specifications

deferred IndexTransaction           -- transaction resolution (put/delete/erase logic)
deferred ResolveAttach              -- attach database resolution
deferred ResolveDetach              -- detach database resolution
