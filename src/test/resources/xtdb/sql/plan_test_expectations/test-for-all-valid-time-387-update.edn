[:project
 {:projections
  [{_iid users.1/_iid}
   {_valid_from users.1/_valid_from}
   {_valid_to users.1/_valid_to}
   {first_name "Sue"}]}
 [:rename
  {:prefix users.1}
  [:scan
   {:db-name "xtdb", :table #xt/table users,
    :columns
    [_valid_to
     _valid_from
     {first_name (or (not (boolean (=== "Sue" first_name))))}
     _iid],
    :clamp-valid-time? true,
    :for-valid-time :all-time}]]]
