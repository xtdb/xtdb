[:project
 {:projections
  [{_iid u.1/_iid}
   {_valid_from u.1/_valid_from}
   {_valid_to u.1/_valid_to}
   {col1 30}]}
 [:rename
  {:prefix u.1}
  [:scan
   {:db-name "xtdb", :table #xt/table t1,
    :columns
    [{col1 (or (not (boolean (=== 30 col1))))}
     _valid_to
     _valid_from
     _iid],
    :clamp-valid-time? true,
    :for-valid-time [:in (current-timestamp) xtdb/end-of-time]}]]]
