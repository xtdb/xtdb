[:project
 {:projections
  [{_iid u.1/_iid}
   {_valid_from u.1/_valid_from}
   {_valid_to u.1/_valid_to}
   {first_name ?_2}
   {id u.1/id}]}
 [:rename
  {:prefix u.1}
  [:scan
   {:db-name "xtdb", :table #xt/table users,
    :columns
    [_valid_to
     {id (== id ?_3)}
     _valid_from
     {first_name (or (not (boolean (=== ?_2 first_name))))}
     _iid],
    :clamp-valid-time? true,
    :for-valid-time [:in ?_0 ?_1]}]]]
